        static void Ejercicio6()
        { /*  Programa que pida al usuario tres números enteros y muestre el mayor de los tres. */

            Console.WriteLine("Escriba el primer número entero: ");
            if (!int.TryParse(Console.ReadLine(), out int num1))
            {
                Console.WriteLine("Entrada inválida. El valor no es un número entero.");
                return;
            }

            Console.WriteLine("Escriba el segundo número entero: ");
            if (!int.TryParse(Console.ReadLine(), out int num2))
            {
                Console.WriteLine("Entrada inválida. El valor no es un número entero.");
                return;
            }

            Console.WriteLine("Escriba el tercer número entero: ");
            if (!int.TryParse(Console.ReadLine(), out int num3))
            {
                Console.WriteLine("Entrada inválida. El valor no es un número entero.");
                return;
            }

            int mayor = (num1 >= num2 && num1 >= num3) ? num1 : (num2 >= num1 && num2 >= num3) ? num2 : num3;
            Console.WriteLine($"El mayor de los tres números es: {mayor}");
        }



        static void Ejercicio7()
        { /*  Programa que pida al usuario una cantidad de horas, de minutos y de segundos (3 
              números diferentes). Comprueba que la hora está en el rango de 0 a 23, los minutos 
              y los segundos de 0 a 59. 
              Si todo es correcto, muestra al usuario la hora en formato HH:MM:SS (2 cifras para cada 
              parte rellenando con 0 a la izquierda si es una cifra), y si no, muestra un mensaje de error. 
              Pista: Repasa la parte de formatear la salida de texto para números enteros.*/

            Console.WriteLine("Indique las horas (entre 0 y 23)");
            int horas = Convert.ToInt32(Console.ReadLine());
            Console.WriteLine("Indique los minutos (entre 0 y 59)");
            int minutos = Convert.ToInt32(Console.ReadLine());
            Console.WriteLine("Indique los segundos (entre 0 y 59)");
            int segundos = Convert.ToInt32(Console.ReadLine());

            Console.WriteLine((0 <= horas && horas <= 23 && 0 <= minutos && minutos <= 59 && 0 <= segundos && segundos <= 59 ? $"La hora es: {horas:D2}:{minutos:D2}:{segundos:D2}" : "Los valores dados no son válidos."));
        }



