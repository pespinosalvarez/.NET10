        static void Ejercicio5()
        { /* Programa que lea dos números por teclado y muestre el resultado de la división del 
             primer número por el segundo. Se debe comprobar que el divisor no puede ser cero.  */

            Console.WriteLine("Escriba el dividendo:");
            double dividendo = Convert.ToDouble(Console.ReadLine());
            Console.WriteLine("Escriba el divisor:");
            double divisor = Convert.ToDouble(Console.ReadLine());
            Console.WriteLine((divisor != 0 ? $"La división de ambos números es:  {dividendo / divisor} " : "No se puede dividir entre 0"));

