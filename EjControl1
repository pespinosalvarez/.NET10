        static void Ejercicio1()
        {
            /*  Programa que lea un número entero por teclado y calcule si es par o impar. Un número 
            es par si el resto (%) de dividir entre 2 da 0. */

            Console.WriteLine("Escribe un número entero: ");
            int numero = Convert.ToInt32(Console.ReadLine());
            string tipoNumero = numero switch
            {
                _ when (numero % 2 == 0) => "par",
                _ => "impar"

            };
            Console.WriteLine(tipoNumero);
        }
        static void Ejercicio1b()
        {
            Console.WriteLine("Escribe un número entero: ");
            int numero = Convert.ToInt32(Console.ReadLine());
            Console.WriteLine($"{numero} es {(numero % 2 == 0 ? "par" : "impar")}");
        }


        static void Ejercicio2()
        { /*  Programa que lea un número entero y muestre si el número es múltiplo de 10 (si el 
              resto de la división entre 10 da 0). */
            Console.WriteLine("Escribe un número entero: ");
            int numero = Convert.ToInt32(Console.ReadLine());
            Console.WriteLine($"{numero}{(numero % 10 == 0 ? " es múltiplo de 10" : " no es múltiplo de 10")}");
